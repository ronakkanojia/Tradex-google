{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Trade": {
      "title": "Trade Transaction",
      "description": "Record of a simulated trade",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "strike": { "type": "number" },
        "type": { "type": "string", "enum": ["CALL", "PUT"] },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "symbol", "strike", "type", "price", "quantity"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profile information"
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "User's trade history"
    }
  }
}
